$numero = 7;

if ($numero < 1 || $numero > 12) {
    echo "Error: número invalid.";
    exit;
}
?> 

<!DOCTYPE html>
<html>
<head>
    <title>Taula de multiplicar</title>
    <style>
        table {
            border-collapse: collapse;
            width: 300px;
            margin-top: 20px;
            font-size: 18px;
        }
        td, th {
            border: 1px solid black;
            padding: 8px;
            text-align: center;
        }
        .parell {
            background-color: gray;
        }
        .senar {
            background-color: lightblue;
        }
    </style>
</head>
<body>
    <h1>Taula de multiplicar del <?php echo $numero; ?> </h1>

    <table>
       <?php
        for ($i = 1; $i <= 10; $i++) {

            if ($i % 2 == 0) {
                $classe = "parell";
            } else {
                $classe = "senar";
            }

            echo "<tr class='" . $classe . "'>";
                echo "<td>$numero</td>";
                echo "<td>x</td>";
                echo "<td>$i</td>";
                echo "<td>=</td>";
                echo "<td>" . ($numero * $i) . "</td>";
            echo "</tr>";
        }
        ?> 
</table>
</body>
</html>